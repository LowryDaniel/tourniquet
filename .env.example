# ── Database ───────────────────────────────────────────────────────────────────
# Default: local SQLite file in the project root. Works on every machine, no
# external services needed.
# For production multi-key deployments, use Postgres:
#   DATABASE_URL=postgresql+psycopg://tourniquet:password@localhost:5432/tourniquet
DATABASE_URL=sqlite+aiosqlite:///./tourniquet_dev.db

# ── Security ───────────────────────────────────────────────────────────────────
# These will be auto-generated when you run `python scripts/init.py`.
# Don't share them. Don't commit them. If you regenerate them, you'll need to
# re-enter all your sk-ant- keys (the old ones can no longer be decrypted).
FERNET_KEY=
SECRET_KEY=

# ── Display ────────────────────────────────────────────────────────────────────
# Currency for caps and alerts. Storage is canonical USD cents internally;
# this only changes what you see. Options: USD GBP EUR JPY CAD AUD
DISPLAY_CURRENCY=USD

# Hard ceiling above which the auto-tune `creep` mode will never raise the cap,
# in USD cents. 10000 = $100/day. Adjust to taste.
ABSOLUTE_CEILING_USD_CENTS=10000

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# Base URL — used for any links Tourniquet generates (alerts, magic links).
# Match the port you run uvicorn on (default 8787).
APP_BASE_URL=http://127.0.0.1:8787

# ── Upstream ───────────────────────────────────────────────────────────────────
# Where Tourniquet forwards your proxied requests. Leave as default unless you
# need to point at a test double.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Email alerts (Resend) ──────────────────────────────────────────────────────
# Empty = email alerts disabled. To enable:
#   1. Sign up at https://resend.com (free tier)
#   2. Verify a domain you own (Resend won't let you send from arbitrary domains)
#   3. Paste the API key here, and put your verified from-address below
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Slack alerts ───────────────────────────────────────────────────────────────
# Empty = disabled. Paste an incoming-webhook URL from your Slack app settings.
# Walkthrough: docs/alerts-setup.md  →  Slack section.
SLACK_WEBHOOK_URL=

# Optional Slack Socket Mode for in-app one-tap actions (no browser hop).
# All three must be set together — webhook + mrkdwn link fallback otherwise.
# Walkthrough: docs/alerts-setup.md  →  "Optional: Slack Socket Mode" section.
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ── Telegram alerts ────────────────────────────────────────────────────────────
# Empty = disabled. Get bot token from @BotFather; chat ID from getUpdates.
# In-app one-tap is automatic — Tourniquet long-polls Telegram so taps apply
# without opening a browser. No public URL or webhook setup needed.
# Walkthrough: docs/alerts-setup.md  →  Telegram section.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: webhook secret if you ever want to switch from polling to webhook.
TELEGRAM_WEBHOOK_SECRET=

# ── Generic webhook ────────────────────────────────────────────────────────────
# Empty = disabled. POST target for Zapier / n8n / Home Assistant etc.
ALERT_WEBHOOK_URL=

# ── macOS notifications ────────────────────────────────────────────────────────
# Set to "true" to enable banner notifications (macOS only). Style options:
#   text   — plain message in the banner
#   action — banner contains a tourniquet:// URL handler link
#   both   — banner contains both the URL and a copy/paste-able CLI line
ENABLE_MAC_NOTIFICATIONS=false
MAC_NOTIFICATION_STYLE=both

# ── Error tracking (Sentry) ────────────────────────────────────────────────────
# Empty = disabled. Set to your Sentry DSN to enable error reporting.
# Note: Sentry is third-party and is the ONLY data egress beyond your alert
# channels. Leave empty for fully local operation.
SENTRY_DSN=
