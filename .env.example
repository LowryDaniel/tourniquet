# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://burnrate:password@localhost:5432/burnrate

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Signing key for magic-link tokens (32+ random bytes, base64-encoded)
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SECRET_KEY=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=alerts@burnrate.ai

# ── Error tracking (Sentry) ────────────────────────────────────────────────────
SENTRY_DSN=
# Leave empty to disable Sentry (safe for local dev)

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
# Options: development | production
LOG_LEVEL=INFO

# Base URL — used in magic-link emails
APP_BASE_URL=http://localhost:8000

# ── Upstream ───────────────────────────────────────────────────────────────────
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Leave as default unless you need to point at a test double
